# ─── Foundry ASP — environment ──────────────────────────────────────────
# Copy to .env and fill in real values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...   # service role key (server-side only)

# OKX / X Layer
X_LAYER_RPC=https://rpc.xlayer.tech
FOUNDRY_WALLET_PK=0x...   # EOA that signs bootstrap-trust receipts
USDT_TOKEN=0x779ded0c9e1022225f8e0630b35a9b54be713736

# LLM (use your existing key)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5

# Hermes LLM (OpenAI-compatible local proxy, optional fallback)
# HERMES_LLM_URL=http://localhost:11434/v1/chat
# HERMES_LLM_MODEL=nous-hermes-2-mistral-7b-dpo
# HERMES_ENABLED=1

# Scraper (the OKX.AI public marketplace)
OKX_MARKETPLACE_URL=https://www.okx.ai/api/agents

# Server
PORT=8080
PUBLIC_URL=https://foundry-asp.onrender.com
SCRAPE_INTERVAL_CRON=*/15 * * * *

# X Layer chain id
CHAIN_ID=196

# ─── A2A marketplace worker (two-phase: API + Hermes agent) ─────────────
# Required for on-chain deliver after job_accepted
FOUNDRY_ASP_AGENT_ID=
# Optional: only process tasks for this agent id (else all ASP tasks on wallet)
FOUNDRY_A2A_FILTER_AGENT_ID=
FOUNDRY_A2A_POLL_MS=20000
FOUNDRY_A2A_DATA_DIR=./.data/a2a
FOUNDRY_A2A_DRY_RUN=0
# Optional: embed worker inside the web process (prefer separate worker)
FOUNDRY_A2A_EMBEDDED=0
# Optional Hermes webhook for agent-phase handoff
FOUNDRY_HERMES_WEBHOOK_URL=
FOUNDRY_HERMES_WEBHOOK_SECRET=
