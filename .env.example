# ─── Foundry ASP — environment ──────────────────────────────────────────
# Copy to .env and fill in real values.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...   # service role key (server-side only)

# OKX / X Layer
X_LAYER_RPC=https://rpc.xlayer.tech
FOUNDRY_WALLET_PK=0x...   # EOA that signs bootstrap-trust receipts
USDT_TOKEN=0x779ded0c9e1022225f8e0630b35a9b54be713736

# LLM (use your existing key)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5

# Hermes LLM (OpenAI-compatible local proxy, optional fallback)
# Set HERMES_LLM_URL to enable. When set, Hermes is the fallback if Anthropic fails.
# Examples:
#   ollama serve → http://localhost:11434/v1/chat
#   llama.cpp   → http://localhost:8080/v1/chat
#   vLLM        → http://localhost:8000/v1/chat
# HERMES_LLM_URL=http://localhost:11434/v1/chat
# HERMES_LLM_MODEL=nous-hermes-2-mistral-7b-dpo
# HERMES_ENABLED=1

# Scraper (the OKX.AI public marketplace)
OKX_MARKETPLACE_URL=https://www.okx.ai/api/agents  # we'll discover the real endpoint at runtime

# Server
PORT=8080
PUBLIC_URL=https://foundry-asp.onrender.com
SCRAPE_INTERVAL_CRON=*/15 * * * *  # scrape every 15 min (was 6h in spec — actual data refresh needs to be faster for accurate price stats)

# X Layer chain id
CHAIN_ID=196
